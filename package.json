{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev --inspect",
    "clean": "rimraf .nuxt .output",
    "build": "npm run clean && nuxi generate",
    "preview": "npm run build && nuxi preview",
    "deploy_test": "nuxi generate && netlify deploy --alias=test --dir=.output/public",
    "deploy": "nuxi generate && netlify deploy --prod --dir=.output/public"
  },
  "dependencies": {
    "@pinia/nuxt": "^0.11.0",
    "better-sqlite3": "^12.2.0",
    "entities": "^6.0.0",
    "gsap": "^3.13.0",
    "modern-normalize": "^3.0.1",
    "nuxi": "^3.25.1",
    "vue": "^3.5.15",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@nuxt/content": "^3.6.3",
    "@nuxt/devtools": "^2.4.1",
    "@nuxt/fonts": "^0.11.4",
    "@nuxt/image": "^1.10.0",
    "@nuxt/scripts": "^0.11.10",
    "@nuxtjs/i18n": "^9.5.4",
    "@types/youtube": "^0.1.2",
    "netlify-cli": "^21.5.0",
    "nuxt": "^3.17.4",
    "rimraf": "^6.0.1",
    "sass": "^1.89.2",
    "swiper": "^11.2.10"
  }
}
