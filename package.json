{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxi dev",
    "clean": "rimraf .nuxt .output",
    "build": "npm run clean && nuxi generate",
    "preview": "npm run build && nuxi preview",
    "deploy_test": "nuxi generate && netlify deploy --alias=test --dir=.output/public",
    "deploy": "nuxi generate && netlify deploy --prod --dir=.output/public"
  },
  "dependencies": {
    "@pinia/nuxt": "^0.11.0",
    "@tailwindcss/cli": "^4.1.10",
    "@vueuse/core": "^13.3.0",
    "better-sqlite3": "^11.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "entities": "^6.0.0",
    "lucide-vue-next": "^0.516.0",
    "modern-normalize": "^3.0.1",
    "nuxi": "^3.25.1",
    "swiper": "^11.2.8",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.10",
    "tw-animate-css": "^1.3.4",
    "vue": "^3.5.15",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@nuxt/content": "^3.5.1",
    "@nuxt/devtools": "^2.4.1",
    "@nuxt/fonts": "^0.11.4",
    "@nuxt/image": "^1.10.0",
    "@nuxtjs/i18n": "^9.5.4",
    "netlify-cli": "^21.5.0",
    "nuxt": "^3.17.4",
    "rimraf": "^6.0.1",
    "sass": "^1.89.2"
  }
}
